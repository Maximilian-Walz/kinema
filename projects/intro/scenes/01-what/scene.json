  "lines": [
    {
      "id": "01-what-l1",
      "from": 0,
      "to": 4.8,
      "text": "This is Kinema — a studio for videos you build out of plain web files."
    },
    {
      "id": "01-what-l2",
      "from": 5,
      "to": 9,
      "text": "Every video is a project: just a folder of scenes."
    },
    {
      "id": "01-what-l3",
      "from": 9.2,
      "to": 12.8,
      "text": "And a scene is three files you already know."
    },
    {
      "id": "01-what-l4",
      "from": 13,
      "to": 17.6,
      "text": "An HTML file for the markup, a CSS file for the look,"
    },
    {
      "id": "01-what-l5",
      "from": 17.8,
      "to": 22,
      "text": "and a JSON file for the timing and the narration."
    },
    {
      "id": "01-what-l6",
      "from": 22.2,
      "to": 28,
      "text": "Nothing is hidden in a database. The files on disk are the whole video."
    }
  ]
}
