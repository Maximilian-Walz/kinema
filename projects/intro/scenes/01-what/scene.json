  "lines": [
    { "id": "01-what-l1", "from": 0, "to": 4.6, "text": "This is Kinema, a small studio for making videos out of web files." },
    { "id": "01-what-l2", "from": 4.8, "to": 8.4, "text": "Everything you're watching right now is HTML and CSS." },
    { "id": "01-what-l3", "from": 9.0, "to": 13.6, "text": "A video is a folder of scenes, and every scene is three files." },
    { "id": "01-what-l4", "from": 13.8, "to": 18.2, "text": "Markup, styles, and a bit of JSON that says what happens when." },
    { "id": "01-what-l5", "from": 18.6, "to": 21.8, "text": "If you can edit a web page, you can edit this." }
  ]
}
