  "lines": [
    {
      "id": "01-what-l1",
      "from": 0,
      "to": 4.6,
      "text": "This is video-studio. It turns plain web files into data-driven videos."
    },
    {
      "id": "01-what-l2",
      "from": 4.8,
      "to": 8.4,
      "text": "Every video is a project: a folder of scenes."
    },
    {
      "id": "01-what-l3",
      "from": 8.6,
      "to": 12.6,
      "text": "And a scene is just three files you already know."
    },
    {
      "id": "01-what-l4",
      "from": 12.8,
      "to": 17.6,
      "text": "An HTML file for the markup, a CSS file for the look,"
    },
    {
      "id": "01-what-l5",
      "from": 17.8,
      "to": 21.8,
      "text": "and a JSON file holding the timing and the narration."
    },
    {
      "id": "01-what-l6",
      "from": 22,
      "to": 27.6,
      "text": "Nothing is hidden in a database. The files on disk are the whole video."
    }
  ]
}
