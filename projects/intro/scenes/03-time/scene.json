  "lines": [
    { "id": "03-time-l1", "from": 0, "to": 4.2, "text": "Hit play, and every scene runs on one global timeline." },
    { "id": "03-time-l2", "from": 4.4, "to": 10.0, "text": "Four lanes share the clock: your scenes, the script, the captions, and your voice." },
    { "id": "03-time-l3", "from": 10.2, "to": 13.0, "text": "Each clip is something you can grab." },
    { "id": "03-time-l4", "from": 13.2, "to": 17.6, "text": "Drag a clip to move it; drag its edge to retime it." },
    { "id": "03-time-l5", "from": 17.8, "to": 23.0, "text": "Everything snaps to the playhead and its neighbours, so the beats line up." },
    { "id": "03-time-l6", "from": 23.2, "to": 28.0, "text": "Every edit writes straight back into the JSON, and undo always has your back." }
