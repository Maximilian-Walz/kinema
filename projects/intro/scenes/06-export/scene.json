    { "id": "06-export-l1", "from": 0, "to": 2.4, "text": "When it looks right, export." },
    { "id": "06-export-l2", "from": 2.6, "to": 5.0, "text": "Pick a frame rate and a scope." },
    { "id": "06-export-l3", "from": 5.2, "to": 9.6, "text": "The studio renders every frame in headless Chrome with time frozen," },
    { "id": "06-export-l4", "from": 9.8, "to": 13.0, "text": "so the motion is identical on every single run." },
    { "id": "06-export-l5", "from": 13.2, "to": 18.0, "text": "It pipes the frames through ffmpeg and muxes in your picked takes." },
    { "id": "06-export-l6", "from": 18.2, "to": 22.8, "text": "Out comes one MP4 — frame for frame, the video you built." }
