    {
      "id": "02-timeline-l1",
      "from": 0,
      "to": 4.2,
      "text": "Hit play, and every scene runs on one global timeline."
    },
    {
      "id": "02-timeline-l2",
      "from": 4.4,
      "to": 8.4,
      "text": "Below the stage, each clip is something you can grab."
    },
    {
      "id": "02-timeline-l3",
      "from": 8.6,
      "to": 13.4,
      "text": "Drag a clip to move it, drag its edge to retime it."
    },
    {
      "id": "02-timeline-l4",
      "from": 13.6,
      "to": 18.4,
      "text": "Everything snaps to the playhead and its neighbours, so the beats line up."
    },
    {
      "id": "02-timeline-l5",
      "from": 18.6,
      "to": 20.2,
      "text": "Made a mistake? Undo."
    },
    {
      "id": "02-timeline-l6",
      "from": 20.4,
      "to": 24,
      "text": "Every edit writes straight back into the scene's JSON."
    },
    {
      "id": "02-timeline-l7",
      "from": 24.2,
      "to": 25.6,
      "text": "That's TIMELINE mode."
    },
    {
      "id": "02-timeline-l8",
      "from": 25.8,
      "to": 29.8,
      "text": "Press F4 for SCENE mode and edit the frame itself."
    },
    {
      "id": "02-timeline-l9",
      "from": 30,
      "to": 34.8,
      "text": "Click any line of text and retype it right in place."
    },
    {
      "id": "02-timeline-l10",
      "from": 35,
      "to": 39,
      "text": "The inspector tabs restyle the look and nudge the timing."
    },
    {
      "id": "02-timeline-l11",
      "from": 39.2,
      "to": 43.6,
      "text": "Retype or restyle, and it writes back to scene.html and scene.css."
    }
  ]
