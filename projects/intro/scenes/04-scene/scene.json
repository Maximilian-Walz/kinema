    { "id": "04-scene-l1", "from": 0, "to": 3.6, "text": "Press F4, and a single scene fills the canvas." },
    { "id": "04-scene-l2", "from": 3.8, "to": 6.4, "text": "Click any element to select it." },
    { "id": "04-scene-l3", "from": 6.6, "to": 11.0, "text": "Double-click, and you retype the text right where it sits." },
    { "id": "04-scene-l4", "from": 11.2, "to": 15.2, "text": "Drag it to reposition, or grab a corner to resize." },
