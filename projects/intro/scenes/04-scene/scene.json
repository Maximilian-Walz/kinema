    { "id": "04-scene-l6", "from": 19.8, "to": 24.0, "text": "Recolour it, or pick an entrance animation from a dropdown." },
    { "id": "04-scene-l7", "from": 24.2, "to": 28.4, "text": "And it all writes straight back to scene.html and scene.css." }
