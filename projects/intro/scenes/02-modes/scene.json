  "lines": [
    { "id": "02-modes-l1", "from": 0, "to": 4.0, "text": "The studio is one window with four modes." },
    { "id": "02-modes-l2", "from": 4.2, "to": 8.6, "text": "RECORD reads your script off a teleprompter and captures your voice." },
    { "id": "02-modes-l3", "from": 8.8, "to": 12.0, "text": "TUNE auditions every take and polishes the sound." },
    { "id": "02-modes-l4", "from": 12.2, "to": 15.4, "text": "TIME places every scene on one global clock." },
    { "id": "02-modes-l5", "from": 15.6, "to": 18.8, "text": "And SCENE composes a single frame, element by element." },
    { "id": "02-modes-l6", "from": 19.0, "to": 23.4, "text": "Press F1 through F4, and the whole window re-flows to whatever you're doing." }
  ]
